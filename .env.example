# Copy to .env and fill in. Not committed (see .gitignore).

# Absolute host path to your Claude Code skills directory, bind-mounted
# read-only into the server container at /skills so known-actors registration
# (packages/server/src/mcp/guardrails/actor-registry.ts) can scan it live,
# without a container rebuild on every edit. Must be an absolute path --
# Compose does not expand `~`.
RIG_SKILLS_HOST_DIR=/absolute/path/to/.claude/skills
